# ==========================================
# Brauni Food — Required Environment Variables
# ==========================================
# Copy this file to .env and fill in your values.

# ---- Django ----
DJANGO_SECRET_KEY=generate-a-random-secret-key-here
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=your-app.railway.app,your-app.onrender.com

# ---- Database (choose one) ----
# Option A: Individual vars
POSTGRES_DB=brauni_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-db-password
POSTGRES_HOST=your-db-host
POSTGRES_PORT=5432

# Option B: Single URL (Railway / Render provide this)
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# ---- E-mail (optional, for error reports) ----
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=user@example.com
# EMAIL_HOST_PASSWORD=password

# ---- Django-Vite (dev only) ----
# Set to "true" only in local development with `npm run dev`
# DJANGO_VITE_DEV_MODE=false

# ---- TLS (production) ----
# SECURE_SSL_REDIRECT=true
# SECURE_HSTS_SECONDS=31536000
